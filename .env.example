# Copy to .env and fill in.

# --- required ---
FRIGATE_URL=http://192.168.10.106:5000

MQTT_HOST=192.168.10.103
MQTT_PORT=1883
MQTT_USER=mqtt
MQTT_PASS=REPLACE_ME

# HA Samba share mount (HA-OS runs in a Proxmox VM, so we write the GIFs
# into HA's /config/www via SMB instead of a bind mount).
# Credentials come from the HA `Samba share` addon → Configuration tab.
HA_HOST=192.168.10.103
SMB_USER=josh
SMB_PASS=REPLACE_ME

# --- optional (defaults shown) ---
# CAMERAS=doorbell
# LABELS=person
# REQUIRED_ZONE=property
# IGNORE_SUBLABELS=Josh
# GIF_FPS=5
# GIF_WIDTH=720
# GIF_MAX_SECONDS=12
# GIF_RETENTION_HOURS=24
# CLIP_FETCH_TIMEOUT_S=45
# LOG_LEVEL=INFO
