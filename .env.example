# Copy to .env and fill in.

# --- required ---
FRIGATE_URL=http://192.168.10.106:5000
MQTT_HOST=192.168.10.103
MQTT_PORT=1883
MQTT_USER=mqtt
MQTT_PASS=REPLACE_ME

# Host path of HA's /config/www directory. On home-debian:
#   docker inspect homeassistant \
#     --format '{{ range .Mounts }}{{ if eq .Destination "/config" }}{{ .Source }}{{ end }}{{ end }}'
# then append /www.
HA_WWW_PATH=/var/lib/docker/volumes/homeassistant_config/_data/www

# --- optional (defaults shown) ---
# CAMERAS=doorbell
# LABELS=person
# REQUIRED_ZONE=property
# IGNORE_SUBLABELS=Josh
# GIF_FPS=5
# GIF_WIDTH=720
# GIF_MAX_SECONDS=12
# GIF_RETENTION_HOURS=24
# CLIP_FETCH_TIMEOUT_S=45
# LOG_LEVEL=INFO
